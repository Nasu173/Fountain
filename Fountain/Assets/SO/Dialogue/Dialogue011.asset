  m_Script: {fileID: 11500000, guid: 4e48ebe7b33625d4f88f53d3b19c0f4d, type: 3}
  m_Name: Dialogue011
  m_EditorClassIdentifier: 
  id: 12
  sequence:
  - speakerEN: People in protective clothing
    textEN: Recovery Team 1 on site. Assessing target area status.
    speakerZH: "\u7A7F\u7740\u9632\u62A4\u670D\u7684\u4EBA"
    textZH: "\u56DE\u65361\u7EC4\u5DF2\u5230\u8FBE\u73B0\u573A\uFF0C\u6B63\u5728\u786E\u8BA4\u76EE\u6807\u533A\u57DF\u60C5\u51B5\u3002\n"
    performName: WalkPerform
  - speakerEN: 
    textEN: ......
    speakerZH: 
    textZH: "\u2026\u2026"
    performName: 
  - speakerEN: People in protective clothing
    textEN: Sweep complete. Target area has been sanitized.
    speakerZH: "\u7A7F\u7740\u9632\u62A4\u670D\u7684\u4EBA"
    textZH: "\u68C0\u67E5\u5B8C\u6BD5\uFF0C\u76EE\u6807\u533A\u57DF\u5DF2\u51C0\u5316\u5B8C\u6BD5\uFF01"
    performName: 
  - speakerEN: People in protective clothing
    textEN: Thanks to these two expendables, we've gathered plenty of new data on
      the entity's behavior.
    speakerZH: "\u7A7F\u7740\u9632\u62A4\u670D\u7684\u4EBA"
    textZH: "\u591A\u4E8F\u4E86\u8FD9\u4E24\u4E2A\u8017\u6750\uFF0C\u83B7\u5F97\u4E86\u4E0D\u5C11\u65B0\u7684\u5B9E\u4F53\u884C\u4E3A\u8BB0\u5F55\u5462"
    performName: 
  - speakerEN: People in protective clothing
    textEN: Sigh... Such a waste. The test  entity is gone.
    speakerZH: "\u7A7F\u7740\u9632\u62A4\u670D\u7684\u4EBA"
    textZH: "\u2026\u5509\uFF0C\u53EA\u662F\u53EF\u60DC\u4E86\uFF0C\u88AB\u6D4B\u5B9E\u4F53\u90FD\u6CA1\u4E86\u2026\u2026"
    performName: 
  dialogueEndPerformName: 
  unlockInput: 0
