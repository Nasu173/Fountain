  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4e48ebe7b33625d4f88f53d3b19c0f4d, type: 3}
  m_Name: Dialogue004
  m_EditorClassIdentifier: 
  id: 4
  sequence:
  - speakerEN: I
    textEN: Hey Boss, what's up?
    speakerZH: "\u6211"
    textZH: "\u5582\uFF0C\u9886\u5BFC\uFF0C\u627E\u6211\u5565\u4E8B\u554A\uFF1F"
    performName: 
  - speakerEN: Telephone
    textEN: You have the nerve to ask?! It's just a small fountain, why isn't it
      fixed yet?
    speakerZH: "\u7535\u8BDD\u90A3\u5934"
    textZH: "\u4F60\u8FD8\u6709\u8138\u95EE\uFF1F\uFF01\u5C31\u4E00\u4E2A\u5C0F\u55B7\u6CC9\u600E\u4E48\u90A3\u4E48\u4E45\u8FD8\u6CA1\u4FEE\u597D\uFF1F\n"
    performName: 
  - speakerEN: I
    textEN: Whoa... take it easy. I'm handling it. I'm going right now.
    speakerZH: "\u6211"
    textZH: "\u60A8\u2026\u60A8\u5148\u6D88\u6D88\u6C14\uFF0C\u6211\u8FD9\u5C31\u53BB\u529E\uFF0C\u8FD9\u5C31\u53BB\u529E\u54C8\u3002"
    performName: 
  - speakerEN: Telephone
    textEN: (Beep... beep...)
    speakerZH: "\u7535\u8BDD\u90A3\u5934"
    textZH: "\uFF08\u561F\u561F\u561F\u2026\u2026\uFF09"
    performName: 
  - speakerEN: I
    textEN: ...Hung up. Asshole. If I didn't need the cash, I'd have quit ages ago.
    speakerZH: "\u6211"
    textZH: "\u2026\u2026\u6302\u6389\u4E86\u3002\u8FD9nt\u8001\u677F\uFF0C\u8981\u4E0D\u662F\u56E0\u4E3A\u90A3\u70B9\u7834\u5DE5\u94B1\uFF0C\u6211\u90FD\u61D2\u5F97\u7406\u4F60\u3002"
    performName: 
  - speakerEN: I
    textEN: That kid is useless. Guess I have to do everything myself.
    speakerZH: "\u6211"
    textZH: "\u8FD9\u81ED\u5C0F\u5B50\u4E00\u70B9\u4E5F\u9760\u4E0D\u4F4F\uFF0C\u8FD8\u5F97\u6211\u4EB2\u81EA\u8DD1\u4E00\u8D9F\u3002"
    performName: 
  dialogueEndPerformName: 
